# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/expense_fluxw?retryWrites=true&w=majority

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# Secret for signing JWTs — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# The canonical URL of your app (no trailing slash)
# In production: your Vercel URL e.g. https://expense-fluxw.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── Password Pepper ─────────────────────────────────────────────────────────
# Server-side secret prepended to every password before bcrypt hashing.
# NEVER store this in the database. NEVER commit the real value to git.
# Generate with: openssl rand -base64 32
# WARNING: changing this value invalidates ALL existing user passwords.
PASSWORD_PEPPER=your-pepper-here-generate-with-openssl-rand-base64-32

# ─── Seed Script ─────────────────────────────────────────────────────────────
# Used by scripts/seed.js to create the default admin account
SEED_ADMIN_EMAIL=admin@expensefluxw.com
SEED_ADMIN_PASSWORD=changeme_before_deploy